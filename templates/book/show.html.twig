{% extends 'base.html.twig' %}

{% block title %}Book
{% endblock %}

{% block body %}
	<h1>Détail du livre
		{{ book.title }}</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ book.id }}</td>
			</tr>
			<tr>
				<th>Title</th>
				<td>{{ book.title }}</td>
			</tr>
			<tr>
				<th>Year</th>
				<td>{{ book.year }}</td>
			</tr>
			<tr>
				<th>Description</th>
				<td>{{ book.description }}</td>
			</tr>
			<tr>
				<th>Auteur</th>
				<td>
					{{ book.bookAuthor.name ?? "Pas d'auteur" }}
				</td>
			</tr>
			<tr>
				<th>Categories</th>
				<td>
					{% for category in book.bookCategory %}
						{{ category.name }}
						{% if not loop.last %},
						{% endif %}
					{% else %}
						Pas de catégorie
					{% endfor %}
				</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('app_book_index') }}">back to list</a>
	{% if app.user and 'ROLE_ADMIN' in app.user.roles %}

		<a href="{{ path('app_book_edit', {'id': book.id}) }}">edit</a>

		{{ include('book/_delete_form.html.twig') }}
	{% endif %}
{% endblock %}
