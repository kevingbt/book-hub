{% extends 'base.html.twig' %}

{% block body %}

<div class="max-w-7xl mx-auto px-6 py-10">

    <h1 class="text-3xl font-bold text-gray-800 mb-10">
        Bienvenue sur <span class="text-teal-700">Book Hub</span>
    </h1>

    <section>
        <h2 class="text-xl font-semibold text-gray-700 mb-6">
             Livres à découvrir
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

            {% for book in books %}
                <div class="bg-white rounded-xl shadow-md p-5 border border-gray-100 
                            hover:shadow-xl hover:-translate-y-1 transition transform duration-300">

                    <h3 class="text-lg font-bold text-gray-800 mb-2">
                        {{ book.title }}
                    </h3>

                    <p class="text-sm text-gray-500 mb-2">
                        {{ book.year }}
                    </p>

                    <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                        {{ book.description }}
                    </p>

                    {% if book.bookAuthor %}
                        <p class="text-xs text-gray-500 italic mb-4">
                            par {{ book.bookAuthor.name }}
                        </p>
                    {% endif %}

                    <a href="{{ path('app_book_show', {'id': book.id}) }}"
                       class="inline-block text-teal-700 font-medium hover:text-teal-900 transition">
                        Voir le livre →
                    </a>

                </div>
            {% else %}
                <p class="text-gray-500">
                    Aucun livre disponible.
                </p>
            {% endfor %}

        </div>
    </section>

</div>

{% endblock %}